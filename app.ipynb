import streamlit as st

from rag.retriever import RecipeRetriever

from agents.recipe_agent import RecipeAgent
from agents.nutrition_agent import NutritionAgent
from agents.substitution_agent import SubstitutionAgent
from agents.planner_agent import PlannerAgent

st.set_page_config(
    page_title="Recipe Preparation Agent"
)

st.title(
    "🍽️ Smart Recipe Preparation Agent"
)

ingredients = st.text_input(
    "Enter ingredients separated by commas"
)

if st.button("Generate Recipe"):

    user_items = [
        x.strip().lower()
        for x in ingredients.split(",")
    ]

    retriever = RecipeRetriever()

    recipe = retriever.search(
        user_items
    )

    if recipe is not None:

        recipe_agent = RecipeAgent()

        nutrition_agent = NutritionAgent()

        substitution_agent = SubstitutionAgent()

        planner_agent = PlannerAgent()

        result = recipe_agent.recommend(
            recipe
        )

        st.subheader(
            result["name"]
        )

        st.write(
            "### Ingredients"
        )

        st.write(
            result["ingredients"]
        )

        st.write(
            "### Instructions"
        )

        st.write(
            result["instructions"]
        )

        st.write(
            "### Nutrition"
        )

        st.write(
            nutrition_agent.get_nutrition(
                recipe
            )
        )

        st.write(
            "### Substitution"
        )

        st.write(
            substitution_agent.suggest(
                recipe
            )
        )

        st.success(
            planner_agent.plan()
        )